rules_version = '2';

// ============================================
// ARIABODAS - REGLAS DE SEGURIDAD DE FIRESTORE
// Se pegan en Firebase Console > Firestore Database > Reglas
// ============================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar: obtiene el documento de usuario de quien
    // está haciendo la petición, buscando por su UID de Firebase Auth
    function usuarioActual() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function esAdmin() {
      return request.auth != null && usuarioActual().rol == 'admin';
    }

    function esDeEstaBoda(bodaId) {
      return request.auth != null
        && usuarioActual().boda_id == bodaId
        && (usuarioActual().rol == 'novios' || usuarioActual().rol == 'wedding_planner');
    }

    // ============================================
    // COLECCIÓN: usuarios
    // ============================================
    match /usuarios/{usuarioId} {
      // Admin ve todos los usuarios; cada quien ve su propio registro
      allow read: if esAdmin() || request.auth.uid == usuarioId;
      // Solo admin puede crear/editar usuarios (dar de alta novios, planners)
      allow write: if esAdmin();
    }

    // ============================================
    // COLECCIÓN: bodas (y sus subcolecciones invitados, mesas)
    // ============================================
    match /bodas/{bodaId} {

      // Ver la boda: público en general puede leer datos básicos para
      // mostrar la invitación (nombres, fecha, diseño). Esto es
      // intencional: la invitación debe ser accesible sin iniciar sesión.
      allow read: if true;

      // Editar el diseño de la boda: SOLO admin (como definimos con Jorge)
      allow write: if esAdmin();

      // -------- Subcolección: invitados --------
      // NO se permite lectura/escritura pública directa aquí.
      // El público interactúa solo a través de las Cloud Functions
      // buscarInvitado y confirmarRSVP, que usan permisos de servidor.
      match /invitados/{invitadoId} {
        allow read: if esAdmin() || esDeEstaBoda(bodaId);
        allow write: if esAdmin() || esDeEstaBoda(bodaId);
      }

      // -------- Subcolección: mesas --------
      match /mesas/{mesaId} {
        allow read: if esAdmin() || esDeEstaBoda(bodaId);
        allow write: if esAdmin() || esDeEstaBoda(bodaId);
      }
    }

    // ============================================
    // NOTA IMPORTANTE:
    // El público (invitados sin cuenta buscando su nombre para RSVP)
    // NO tiene acceso directo aquí - por diseño, para que no puedan
    // leer ni editar datos de otros invitados. Ese acceso se maneja
    // aparte con Cloud Functions (ver archivo cloud_functions_rsvp.js),
    // que sí pueden leer/escribir usando permisos de administrador
    // del servidor, pero solo entregan exactamente lo necesario.
    // ============================================
  }
}
